      "title": "Query Latency p95 / p99 by Tier",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le, tier) (rate(keiro_query_latency_seconds_bucket[5m])))",
          "legendFormat": "p95 — {{tier}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le, tier) (rate(keiro_query_latency_seconds_bucket[5m])))",
          "legendFormat": "p99 — {{tier}}",
          "refId": "B"
        }
