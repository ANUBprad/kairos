generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

/// Better Auth core tables

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  emailVerified Boolean  @default(false)
  name          String?
  image         String?
  passwordHash  String?
  role          UserRole @default(USER)

  banned     Boolean   @default(false)
  banReason  String?
  banExpires DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions         Session[]
  accounts         Account[]
  members          Member[]
  ownedOrgs        Organization[]     @relation("OrganizationOwner")
  activityLogs     ActivityLog[]
  Document         Document[]
  documentVersions DocumentVersion[]
  documentActivity DocumentActivity[]
  conversations    Conversation[]
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  token     String   @unique

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model Account {
  id           String  @id @default(cuid())
  accountId    String  @db.VarChar(255)
  providerId   String  @db.VarChar(64)
  userId       String
  accessToken  String? @db.Text
  refreshToken String? @db.Text
  idToken      String? @db.Text
  password     String? @db.VarChar(255)
  scope        String? @db.VarChar(255)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String   @db.VarChar(255)
  value      String   @db.Text
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier])
  @@index([expiresAt])
}

enum UserRole {
  SUPERADMIN
  ADMIN
  USER
}

/// Organization / Multi-tenant

model Organization {
  id       String  @id @default(cuid())
  name     String  @db.VarChar(255)
  slug     String  @unique @db.VarChar(128)
  logo     String?
  metadata Json?

  ownerId String
  owner   User   @relation("OrganizationOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  members  Member[]
  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

model Member {
  id             String     @id @default(cuid())
  role           MemberRole @default(MEMBER)
  organizationId String
  userId         String
  invitedBy      String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

/// Projects

model Project {
  id          String  @id @default(cuid())
  name        String  @db.VarChar(255)
  description String? @db.Text
  slug        String  @unique @db.VarChar(128)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  knowledgeBases KnowledgeBase[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

/// Knowledge Bases

model KnowledgeBase {
  id          String  @id @default(cuid())
  name        String  @db.VarChar(255)
  description String? @db.Text

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  documents         Document[]
  conversations     Conversation[]
  experiments       Experiment[]
  experimentRuns    ExperimentRun[]
  benchmarkDatasets BenchmarkDataset[]

  retrievalConfig Json? @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

/// Conversations / AI Chat

model Conversation {
  id       String  @id @default(cuid())
  title    String? @db.VarChar(255)
  model    String  @default("gpt-4o-mini")
  provider String  @default("openai")

  knowledgeBaseId String
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([knowledgeBaseId])
  @@index([userId])
  @@index([knowledgeBaseId, userId])
}

model Message {
  id      String @id @default(cuid())
  role    String @db.VarChar(16)
  content String @db.Text
  tokens  Int?

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  citations MessageCitation[]

  createdAt DateTime @default(now())

  @@index([conversationId])
  @@index([conversationId, createdAt])
}

model MessageCitation {
  id           String @id @default(cuid())
  chunkId      String
  documentId   String @db.VarChar(255)
  documentName String @db.VarChar(255)
  chunkIndex   Int
  pageNumber   Int?
  excerpt      String @db.Text
  similarity   Float?

  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([messageId])
}

/// Documents / Uploads

model Document {
  id              String         @id @default(cuid())
  name            String         @db.VarChar(255)
  fileType        String         @db.VarChar(64)
  size            Int
  fileHash        String?        @db.VarChar(128)
  storageProvider String         @default("cloudinary")
  storageKey      String         @db.VarChar(512)
  storageUrl      String?        @db.Text
  metadata        Json?
  status          DocumentStatus @default(QUEUED)

  knowledgeBaseId String
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  uploadedById String?
  uploadedBy   User?   @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  chunks         DocumentChunk[]
  versions       DocumentVersion[]
  activities     DocumentActivity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([knowledgeBaseId, fileHash])
  @@index([knowledgeBaseId])
  @@index([uploadedById])
  @@index([status])
  @@index([knowledgeBaseId, status])
}

model DocumentChunk {
  id         String @id @default(cuid())
  content    String @db.Text
  index      Int
  metadata   Json?
  tokenCount Int?

  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  embedding DocumentEmbedding?

  createdAt DateTime @default(now())

  @@index([documentId])
  @@index([documentId, index])
}

model DocumentEmbedding {
  id         String @id @default(cuid())
  model      String @default("text-embedding-3-small")
  dimensions Int    @default(1536)
  status     String @default("pending")

  chunkId String        @unique
  chunk   DocumentChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([chunkId])
}

model DocumentVersion {
  id         String  @id @default(cuid())
  version    Int     @default(1)
  fileType   String  @db.VarChar(64)
  size       Int
  storageKey String  @db.VarChar(512)
  storageUrl String? @db.Text
  metadata   Json?
  changeNote String? @db.Text

  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([documentId, version])
  @@index([documentId])
}

model DocumentActivity {
  id      String @id @default(cuid())
  action  String @db.VarChar(64)
  details Json?

  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([documentId, createdAt])
  @@index([documentId])
}

enum DocumentStatus {
  QUEUED
  UPLOADING
  STORED
  EXTRACTING
  CHUNKING
  EMBEDDING_PENDING
  EMBEDDING
  INDEXED
  READY
  ERROR
}

/// Experiment Tracking

model Experiment {
  id          String  @id @default(cuid())
  name        String  @db.VarChar(255)
  description String? @db.Text

  knowledgeBaseId String
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  configA Json
  configB Json?

  status String  @default("draft")
  winner String?

  runs ExperimentRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([knowledgeBaseId])
}

model ExperimentRun {
  id              String @id @default(cuid())
  configSnapshot  Json
  query           String @db.Text
  retrievedChunks Json
  metrics         Json?
  debug           Json?

  latencyEmbedding    Float?
  latencyVectorSearch Float?
  latencyPromptBuild  Float?
  latencyLlmResponse  Float?
  totalLatency        Float?

  chunkCount Int?
  tokensUsed Int?

  embeddingModel String?
  retrievalMode  String?

  experimentId String?
  experiment   Experiment? @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  knowledgeBaseId String
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([experimentId])
  @@index([knowledgeBaseId])
}

/// Benchmark Datasets

model BenchmarkDataset {
  id          String  @id @default(cuid())
  name        String  @db.VarChar(255)
  description String? @db.Text
  source      String? @db.VarChar(128)

  knowledgeBaseId String?
  knowledgeBase   KnowledgeBase? @relation(fields: [knowledgeBaseId], references: [id], onDelete: SetNull)

  questions    BenchmarkQuestion[]
  runs         BenchmarkRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([knowledgeBaseId])
}

model BenchmarkQuestion {
  id              String  @id @default(cuid())
  question        String  @db.Text
  expectedAnswer  String? @db.Text
  expectedContext String? @db.Text
  referenceDocId  String? @db.VarChar(255)
  metadata        Json?

  datasetId String
  dataset   BenchmarkDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  results BenchmarkResult[]

  createdAt DateTime @default(now())

  @@index([datasetId])
}

model BenchmarkResult {
  id         String            @id @default(cuid())
  questionId String
  question   BenchmarkQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  retrievedChunkIds String? @db.Text
  retrievedChunks   Json?
  generatedAnswer   String? @db.Text
  promptUsed        String? @db.Text

  retrievalMetrics  Json?
  generationMetrics Json?

  latencyEmbeddingMs  Float?
  latencySearchMs     Float?
  latencyPromptMs     Float?
  latencyGenerationMs Float?
  totalLatencyMs      Float?

  configSnapshot Json?

  runId String
  run   BenchmarkRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([runId])
  @@index([questionId])
}

model BenchmarkRun {
  id          String  @id @default(cuid())
  name        String? @db.VarChar(255)
  description String? @db.Text
  status      String  @default("running")

  configSnapshot Json

  aggregatedMetrics Json?

  datasetId String
  dataset   BenchmarkDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  results BenchmarkResult[]

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([datasetId])
}

/// Activity / Audit Logs

model ActivityLog {
  id         String  @id @default(cuid())
  action     String  @db.VarChar(128)
  resource   String? @db.VarChar(255)
  resourceId String? @db.VarChar(255)
  metadata   Json?
  ipAddress  String?
  userAgent  String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, action])
}


