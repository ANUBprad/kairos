# =============================================================================
# Kairos Portal — Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
# =============================================================================

# --- Database ---
# Required. PostgreSQL connection string for Prisma.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kairos?schema=public

# --- Authentication (Better Auth) ---
# Required. Secret used to sign/encrypt auth tokens.
# Generate via: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Optional. Public URL of the auth server. Defaults to http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# --- Storage (Cloudinary) ---
# Required for file uploads. Get your credentials at https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- OAuth / Social Login ---
# GitHub: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- AI / LLM Providers ---
# Optional. Set at least one to enable AI chat + embeddings.
# Default provider (openai | gemini):
AI_PROVIDER=openai

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Google Gemini: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004
