# =============================================================================
# Kairos Portal — Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# Required variables are marked with [Required]
# Optional variables are marked with [Optional]
#
# IMPORTANT: Never commit .env.local to version control.
# All secrets MUST be at least 32 characters for BETTER_AUTH_SECRET.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# [Required] PostgreSQL connection string for Prisma ORM.
# Used for all database operations: knowledge bases, documents, chunks, etc.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kairos?schema=public

# [Optional] Direct connection URL (bypasses connection pooling).
# Not needed for local PostgreSQL or non-pooled connections.
# DIRECT_URL=

# -----------------------------------------------------------------------------
# Authentication (Better Auth)
# -----------------------------------------------------------------------------

# [Required] Secret key for signing and encrypting authentication tokens.
# Generate a secure secret: openssl rand -base64 32
# MUST be at least 32 characters.
BETTER_AUTH_SECRET=

# [Required in production] Public URL of the auth server.
# Set to your production URL (e.g., https://your-app.vercel.app).
# If unset, the auth client uses same-origin requests.
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# File Storage (Cloudinary)
# -----------------------------------------------------------------------------

# [Required] Cloudinary credentials for document storage and file uploads.
# Sign up free at: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# -----------------------------------------------------------------------------
# OAuth Providers
# -----------------------------------------------------------------------------

# [Optional] GitHub OAuth for social login.
# Create an OAuth app at: https://github.com/settings/developers
# Set Authorization callback URL to: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# AI / LLM Providers
# -----------------------------------------------------------------------------

# [Optional] Default AI provider for chat and embeddings.
# Options: "openai" or "gemini". Defaults to "openai".
AI_PROVIDER=openai

# --- OpenAI ---
# [Optional] OpenAI API key for GPT models and embeddings.
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Google Gemini ---
# [Optional] Google Gemini API key for chat and embeddings.
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# -----------------------------------------------------------------------------
# Analytics (Optional)
# -----------------------------------------------------------------------------

# [Optional] PostHog analytics for usage tracking.
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# -----------------------------------------------------------------------------
# Billing (Optional — Stripe)
# -----------------------------------------------------------------------------

# [Optional] Stripe secret key for billing.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------

# [Optional] Node.js environment mode. Defaults to "development".
# Options: "development", "production", "test"
# NODE_ENV=development
