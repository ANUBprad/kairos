# =============================================================================
# Kairos Portal — Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
# =============================================================================

# --- Database ---
# Required. PostgreSQL connection string for Prisma.
# Generate via: openssl rand -base64 32
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kairos?schema=public

# --- Authentication (Better Auth) ---
# Required. Secret used to sign/encrypt auth tokens.
# Generate via: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Optional. Public URL of the auth server. Defaults to http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# --- Email (Resend) ---
# Required for transactional emails (welcome, password reset, contact).
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=

# Optional. Sender email address. Defaults to noreply@kairos.dev
KAIROS_EMAIL_FROM=noreply@kairos.dev

# Optional. Recipient for contact form submissions. Defaults to support@kairos.dev
KAIROS_CONTACT_EMAIL=support@kairos.dev

# --- OAuth / Social Login ---
# Optional. Set both ID and secret to enable the provider.
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
