# Kairos Portal — Environment Configuration

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kairos?schema=public

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

AI_PROVIDER=openai #(or gemini)

# Use one holder at a time, depending on the AI provider you want to use. If you want to use OpenAI, fill in the OpenAI keys and leave the Gemini keys empty. If you want to use Gemini, fill in the Gemini keys and leave the OpenAI keys empty.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004
