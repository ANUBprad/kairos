# Kairos Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# =============================================================================
# Portal (Next.js) — apps/portal/
# =============================================================================

# Required. PostgreSQL connection string.
# Generate BETTER_AUTH_SECRET via: openssl rand -base64 32
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kairos?schema=public
BETTER_AUTH_SECRET=
# Optional. Defaults to http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Required for emails. Get your key at https://resend.com/api-keys
RESEND_API_KEY=
# Optional. Defaults to noreply@kairos.dev
KAIROS_EMAIL_FROM=noreply@kairos.dev
KAIROS_CONTACT_EMAIL=support@kairos.dev

# Optional — set both ID + secret to enable each OAuth provider
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# =============================================================================
# Gateway (Go) — gateway/
# Intelligence (Python) — intelligence/
# =============================================================================

# --- API Keys ---
# At least one LLM provider API key is required
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
KEIRO_OLLAMA_URL=http://localhost:11434

# --- Service Configuration ---
KEIRO_ENVIRONMENT=development
KEIRO_SECRET=change-me-to-a-random-secret
KEIRO_API_SECRET=change-me-to-a-random-secret

# --- Ports (optional, defaults shown) ---
INTELLIGENCE_PORT=28080
API_PORT=8000
DASHBOARD_PORT=8501
GATEWAY_PORT=8080

# --- ChromaDB ---
KEIRO_CHROMA_STORE_HOST=localhost
KEIRO_CHROMA_STORE_PORT=7777

# --- Rate Limiting ---
KEIRO_RATE_LIMIT=60
KEIRO_BURST_LIMIT=100

# --- Cache ---
KEIRO_CACHE_TTL=300
KEIRO_CACHE_MAX_SIZE=1000
KEIRO_CACHE_SIMILARITY_THRESHOLD=0.85

# --- File Upload ---
KEIRO_MAX_FILE_SIZE=10485760

# --- Grafana (Docker only) ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
