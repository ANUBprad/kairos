# =============================================================================
# Kairos — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# This file configures the full Kairos stack:
#   - Portal (Next.js): apps/portal/
#   - Gateway (Go): gateway/
#   - Intelligence (Python): intelligence/
# =============================================================================

# Portal (Next.js) — apps/portal/

# [Required] PostgreSQL connection string for Prisma ORM.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kairos?schema=public

# [Optional] Direct connection URL (bypasses connection pooling).
# Required for Supabase: use the "Transaction" mode connection string.
# DIRECT_URL=

# [Required] Secret for signing authentication tokens.
# Generate via: openssl rand -base64 32
BETTER_AUTH_SECRET=

# [Optional] Public auth URL. Defaults to http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# [Optional] GitHub OAuth credentials.
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# [Optional] Cloudinary credentials for file storage.
# Sign up at: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# [Optional] Default AI provider ("openai" or "gemini").
AI_PROVIDER=openai

# [Optional] OpenAI API key for chat and embeddings.
OPENAI_API_KEY=

# [Optional] Google Gemini API key for chat and embeddings.
GEMINI_API_KEY=

# =============================================================================
# Gateway (Go) — gateway/
# =============================================================================

# [Optional] Gateway server configuration.
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080

# [Required] Shared authentication secret for gateway requests.
KAIROS_SECRET=change-me-to-a-random-secret

# [Optional] Cache configuration.
KAIROS_CACHE_MAX_SIZE=1000
KAIROS_CACHE_TTL=300
KAIROS_CACHE_SIMILARITY_THRESHOLD=0.85

# [Optional] Rate limiting.
KAIROS_RATE_LIMIT=60
KAIROS_BURST_LIMIT=100

# [Optional] File upload limit (bytes). Default: 10MB.
MAX_FILE_SIZE=10485760

# =============================================================================
# Intelligence (Python) — intelligence/
# =============================================================================

# [Optional] Intelligence service configuration.
INTELLIGENCE_PORT=28080
KAIROS_ENVIRONMENT=development

# [Required] Shared API secret for service authentication.
KAIROS_API_SECRET=change-me-to-a-random-secret

# [Optional] Embedding provider ("local", "openai", or "gemini").
KAIROS_EMBEDDING_MODEL=local

# [Optional] Chunking configuration.
KAIROS_CHUNK_SIZE=1024
KAIROS_OVERLAP=150

# [Optional] LLM provider ("gemini", "openai", or "ollama").
KAIROS_LLM_PROVIDER=

# [Optional] ChromaDB configuration.
CHROMA_STORE_HOST=localhost
CHROMA_STORE_PORT=7777

# [Optional] HuggingFace token for local embeddings.
# HF_TOKEN=

# =============================================================================
# Docker (Optional) — docker-compose.yml
# =============================================================================

# [Optional] Grafana credentials (Docker only).
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
